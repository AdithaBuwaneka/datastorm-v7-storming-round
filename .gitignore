# Python
__pycache__/
*.py[cod]
*.so
*.egg-info/
.ipynb_checkpoints/

# Virtual envs
venv/
env/
.venv/

# Secrets — never commit
.env
.env.local
.env.*.local
**/.env
**/.env.local
webapp/backend/.env
webapp/frontend/.env.local

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# MS Office lock files
~$*

# Large/derived data — keep folder structure via .gitkeep but ignore content
data/source/*
!data/source/.gitkeep
!data/source/README.md
data/bronze/*.csv
data/bronze/*.xlsx
data/bronze/*.json
# But DO commit the team-curated Jan 2026 holiday lookup
# (sourced from Sri Lanka government calendar; required input to gold_features)
!data/bronze/jan_2026_holidays.csv
!data/bronze/_manifest.json
data/bronze/poi_raw/*.json
data/bronze/poi_raw/*.parquet
data/silver/clean/*.parquet
data/silver/quarantine/*.parquet
data/silver/quarantine/*.csv
data/gold/*.parquet
# Whitelist the five gold parquets the web app backend needs at runtime
# (so the Hugging Face Space deployment can ship without re-running the
# pipeline). Together they are ~8 MB, well within GitHub limits.
!data/gold/outlet_features.parquet
!data/gold/counterfactuals.parquet
!data/gold/dormancy_risk.parquet
!data/gold/outlet_clusters.parquet
!data/gold/outlet_actions.parquet

# Final outputs and audit artifacts ARE committed so reviewers can inspect
# without running the full pipeline (they are reproducible from src/).
# Explicit allows for everything under outputs/:
!outputs/
!outputs/audit/
!outputs/*.csv
!outputs/audit/*.csv
!outputs/audit/*.png
!outputs/audit/*.md

# Pipeline run logs (regenerated on every run, not deliverables)
outputs/*.log
outputs/*_log.txt
outputs/_pipeline_run_log.txt

# Auto-generated bronze manifest is small + portable — commit it as proof of
# raw-file integrity (sha256 + row counts).
!data/bronze/_manifest.json

# Report deliverables (.pdf + .docx) ARE committed
!report/
report/figures/*.png
