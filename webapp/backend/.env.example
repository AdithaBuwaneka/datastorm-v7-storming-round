# Copy this file to .env and fill in your keys.
# The .env file is git-ignored; never commit your real key.

# Google Gemini API key — required for the XAI narrative endpoint.
# Get one free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Gemini model. Default: gemini-2.5-flash (fast + free tier).
GEMINI_MODEL=gemini-2.5-flash

# Optional: override repo root if running from a different directory.
# REPO_ROOT=D:/DataStorm/datastorm-v7-storming-round
